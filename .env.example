MODE=LOCAL
LOG_LEVEL=INFO
POSTGRES_DB=artshop
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
# For local dev: localhost. For Docker prod: use 'db' and 'redis'
DB_HOST=localhost
DB_PORT=5432
REDIS_HOST=localhost
REDIS_PORT=6379
JWT_SECRET_KEY=change-this-secret-key-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
ADMIN_EMAILS=["admin@example.com"]

# Frontend: set in docker-compose.prod.yml build args for prod
NEXT_PUBLIC_API_URL=http://localhost:8000

# Monitoring: Dozzle log viewer password (only needed in .env.prod on server)
DOZZLE_PASSWORD=change-this-in-production
