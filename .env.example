MODE=LOCAL
LOG_LEVEL=INFO
POSTGRES_DB=artshop
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
# For local dev: localhost. For Docker prod: use 'db' and 'redis'
DB_HOST=localhost
DB_PORT=5432
REDIS_HOST=localhost
REDIS_PORT=6379
JWT_SECRET_KEY=change-this-secret-key-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
# false for local HTTP dev; set to true in .env.prod (HTTPS)
COOKIE_SECURE=false
ADMIN_EMAILS=["admin@example.com"]

# Frontend: set in docker-compose.prod.yml build args for prod
NEXT_PUBLIC_API_URL=http://localhost:8000

# Google OAuth (Frontend: passed as Docker build arg; Backend: validates token)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Google Maps Places API (optional, enables address autocomplete in checkout)
# Get key from: https://console.cloud.google.com/apis/credentials
# Enable "Places API" in the Google Cloud Console
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# --- PostHog Analytics ---
# Get from: https://eu.posthog.com (Project Settings â†’ Project API Key)
# Use EU cloud for GDPR compliance: https://eu.i.posthog.com
NEXT_PUBLIC_POSTHOG_KEY=phc_xxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# Tracking: Dozzle log viewer password (only needed in .env.prod on server)
DOZZLE_PASSWORD=change-this-in-production

# --- EMAIL SETTINGS (SMTP) ---
# Settings for sending emails (the "bot / courier" account).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=technical_sender_bot@gmail.com
SMTP_PASSWORD=your_16_character_app_password

# --- Monobank Acquiring (Payment Gateway) ---
# Test token from https://api.monobank.ua/ (for testing only).
# Production token from https://web.monobank.ua/ (requires Ð¤ÐžÐŸ/business account).
MONOBANK_TOKEN=your_monobank_token_here
# Public HTTPS URL for Monobank to POST payment status webhooks.
MONOBANK_WEBHOOK_URL=https://your-domain.com/payments/webhook
# URL to redirect buyer after payment (success or failure page).
MONOBANK_REDIRECT_URL=https://your-domain.com/checkout/success

# --- Prodigi Print-on-Demand ---
# API key from https://dashboard.prodigi.com/settings/api
PRODIGI_API_KEY=your_prodigi_api_key_here
# true uses the sandbox API; false uses live production API.
PRODIGI_SANDBOX=true
# Public HTTPS backend URL used in Prodigi callback and asset URLs.
PUBLIC_BASE_URL=https://your-domain.com
# Optional shared secret added to Prodigi callback URLs and checked on receipt.
PRODIGI_WEBHOOK_SECRET=change-this-prodigi-webhook-secret

# --- Telegram Bot Integration ---
# Create your bot at https://t.me/BotFather -> /newbot
# Used only for owner alerts when a customer places an order.
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
# Your personal Telegram chat_id for new-order notifications.
# Get it: message @userinfobot in Telegram -> it replies with your chat_id.
TELEGRAM_ADMIN_CHAT_ID=your_chat_id_here
